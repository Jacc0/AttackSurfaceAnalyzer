@using Microsoft.CST.AttackSurfaceAnalyzer.Types
@using Microsoft.CST.AttackSurfaceAnalyzer.Objects
@using Microsoft.CST.AttackSurfaceAnalyzer.Cli.Objects
@inject Microsoft.CST.AttackSurfaceAnalyzer.Cli.AppData appData

<div class="form-inline pb-3">
    <label class="mr-2" for="ResultType">Result Type:</label>
    <select class="form-control mr-2" id="ResultType" @bind="SelectedResultType">
        @foreach (var resultType in foundResultTypes)
        {
            <option value="@resultType.Key">@resultType.Key : @resultType.Value </option>
        }
    </select>

    @if (!IsTreeViewSupported(SelectedResultType))
    {
        <label class="mr-2" for="MaxResults">View:</label>
        <select class="form-control" id="MaxResults" @bind="MaxResults">
            <option value="50">50</option>
            <option selected value="100">100</option>
            <option value="250">250</option>
            <option value="500">500</option>
        </select>
    }
    else if (foundResultTypes.ContainsKey((RESULT_TYPE)Enum.Parse(typeof(RESULT_TYPE), SelectedResultType)) && foundResultTypes[(RESULT_TYPE)Enum.Parse(typeof(RESULT_TYPE), SelectedResultType)] > 10000)
    {
        <span class="text-warning ml-2">Displaying first 10,000 results in tree view.</span>
    }
</div>

@if (pageCount > 0)
{
    <div class="row">
        <div class="col-6" style="height: 70vh; overflow-y: auto; border-right: 1px solid #444;">
            @if (IsTreeViewSupported(SelectedResultType))
            {
                <ul class="tree-list">
                    @foreach (var root in fileTreeRoots.Values.OrderBy(x => x.Name))
                    {
                        <TreeView Node="root" OnSelected="SetDetailed" />
                    }
                </ul>
            }
            else
            {
                @for (int i = 0; i < analysisResults.Count; i++)
                {
                    var result = analysisResults[i];
                    var resultNumber = offset + i + 1;
                    <div class="pb-2 @(result == detailedResult ? "bg-custom-secondary" : "")" style="cursor:pointer" @onclick="() => SetDetailed(result)">
                        <div>
                            <span class="result-number">@resultNumber. </span>
                            <span class="result-text">@result.Analysis: @result.Identity</span>
                        </div>
                    </div>
                }
            }
        </div>
        <div class="col-6" style="height: 70vh; overflow-y: auto;">
            @if (detailedResult != null)
            {
                <h4>Details: @detailedResult.Identity</h4>
                <p>Change: @detailedResult.ChangeType</p>
                @foreach (var rule in detailedResult.Rules)
                {
                    <div class="rule-text"><strong>@rule.Name</strong>: @rule.Description</div>
                }
                <hr />
                @if (detailedResult.Diffs.Any())
                {
                    <h5>Differences</h5>
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Field</th>
                                <th>Before</th>
                                <th>After</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var diff in detailedResult.Diffs)
                            {
                                <tr>
                                    <td>@diff.Field</td>
                                    <td style="word-break: break-all">@diff.Before</td>
                                    <td style="word-break: break-all">@diff.After</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
            else
            {
                <p>Select an item to view details.</p>
            }
        </div>
    </div>

    @if (!IsTreeViewSupported(SelectedResultType))
    {
        <nav aria-label="Paged results navigation" class="mt-3">
            <ul class="pagination">
                <li class="page-item">
                    <a class="page-link page-step" aria-label="Previous page" @onclick="() => GetResultsPageByOffset(-1)">
                        <span aria-hidden="true">&lt;</span>
                        <span class="sr-only">Previous</span>
                    </a>
                </li>
                @for (int i = 1; i <= pageCount; i++)
                {
                    var pageNum = i;
                    <li class="page-item @GetPageState(i)"><a class="page-link" aria-label="Page-@pageNum" @onclick="() => GetResultsPage(pageNum)">@pageNum</a></li>
                }
                <li class="page-item">
                    <a class="page-link page-step" aria-label="Next page" @onclick="() => GetResultsPageByOffset(1)">
                        <span aria-hidden="true">&gt;</span>
                        <span class="sr-only">Next</span>
                    </a>
                </li>
            </ul>
        </nav>
    }
}
else 
{ 
    <p>0 results found for type @SelectedResultType.</p>
}

@code {
    string _firstRunId = string.Empty;
    string _secondRundId = string.Empty;
    string _analysesHash = string.Empty;
    string _monitorRunId = string.Empty;

    [Parameter]
    public string FirstRunId { get { return _firstRunId; } set { _firstRunId = value; OnInitialized(); } }
    [Parameter]
    public string SecondRunId { get { return _secondRundId; } set { _secondRundId = value; OnInitialized(); } }
    [Parameter]
    public string AnalysesHash { get { return _analysesHash; } set { _analysesHash = value; OnInitialized(); } }
    [Parameter]
    public string MonitorRunId { get { return _monitorRunId; } set { _monitorRunId = value; OnInitialized(); } }

    CompareResult? detailedResult;
    Dictionary<string, TreeNode> fileTreeRoots = new Dictionary<string, TreeNode>();

    void SetDetailed(CompareResult result)
    {
        detailedResult = result;
        this.StateHasChanged();
    }

    protected override void OnInitialized()
    {
        ParseOptsToResultTypes();
        UpdatePageCount();
        GetResultsPage(1);
        base.OnInitialized();
    }

    Dictionary<RESULT_TYPE, int> foundResultTypes = new Dictionary<RESULT_TYPE, int>();
    public List<CompareResult> analysisResults = new List<CompareResult>();
    int offset = 0;
    int currentPage = 1;
    int pageCount = 0;

    int _maxResults = 100;
    int MaxResults
    {
        get { return _maxResults; }
        set
        {
            _maxResults = value;
            UpdatePageCount();
            GetResultsPage(1);
        }
    }

    string _selectedResultType = "FILE";
    string SelectedResultType
    {
        get { return _selectedResultType; }
        set
        {
            _selectedResultType = value;
            UpdatePageCount();
            GetResultsPage(1);
        }
    }

    void GetResultsPage(int selectedPage)
    {
        if (pageCount < 1) { return; }
        currentPage = selectedPage;
        var limit = IsTreeViewSupported(SelectedResultType) ? 10000 : MaxResults;
        offset = limit * (selectedPage - 1);
        GetAnalysisResults();
        BuildTree();
        this.StateHasChanged();
    }

    void GetResultsPageByOffset(int pageOffset)
    {
        var selectedPage = currentPage + pageOffset;
        if (selectedPage < 1) { selectedPage = 1;}
        else if (selectedPage > pageCount) { selectedPage = pageCount; }
        GetResultsPage(selectedPage);
    }

    string GetPageState(int selectedPage)
    {
        return selectedPage == currentPage ? "active" : "";
    }

    public void UpdatePageCount()
    {
        if (foundResultTypes.ContainsKey((RESULT_TYPE)Enum.Parse(typeof(RESULT_TYPE), SelectedResultType)))
        {
            var resultType = (RESULT_TYPE)Enum.Parse(typeof(RESULT_TYPE), SelectedResultType);
            var found = foundResultTypes[resultType];
            var limit = IsTreeViewSupported(SelectedResultType) ? 10000 : MaxResults;
            pageCount = (int)Math.Ceiling((double)found / limit);
        }
        else
        {
            pageCount = 0;
        }
        currentPage = 1;
    }

    public void GetAnalysisResults()
    {
        if (AttackSurfaceAnalyzerClient.DatabaseManager is null)
        {
            analysisResults = new List<CompareResult>();
            return;
        }
        var resultTypeString = SelectedResultType;
        var resultType = (RESULT_TYPE)Enum.Parse(typeof(RESULT_TYPE), resultTypeString);
        var limit = IsTreeViewSupported(resultTypeString) ? 10000 : MaxResults;

        switch (resultType)
        {
            case RESULT_TYPE.FILEMONITOR:
                analysisResults = AttackSurfaceAnalyzerClient.DatabaseManager.GetComparisonResults(string.Empty, MonitorRunId, AnalysesHash, resultType, offset, MaxResults);
                break;
            default:
                analysisResults = AttackSurfaceAnalyzerClient.DatabaseManager.GetComparisonResults(FirstRunId, SecondRunId, AnalysesHash, resultType, offset, limit);
                break;
        }
    }

    void BuildTree()
    {
        fileTreeRoots.Clear();
        var selectedType = SelectedResultType;
        if (IsTreeViewSupported(selectedType))
        {
            if (selectedType == "PORT")
            {
                foreach (var res in analysisResults)
                {
                    var parts = res.Identity.Split(':');
                    if (parts.Length > 0)
                    {
                        var rootName = string.IsNullOrEmpty(parts[0]) ? "Any" : parts[0];
                        if (!fileTreeRoots.ContainsKey(rootName))
                        {
                            fileTreeRoots[rootName] = new TreeNode { Name = rootName, FullPath = rootName, IsExpanded = true };
                        }
                        fileTreeRoots[rootName].AddPath(res.Identity, res, 1, ':');
                    }
                }
            }
            else
            {
                foreach (var res in analysisResults)
                {
                    var parts = res.Identity.Split(new[] { '\\', '/' }, StringSplitOptions.RemoveEmptyEntries);
                    if (parts.Length > 0)
                    {
                        var rootName = parts[0];
                        if (res.Identity.StartsWith("\\\\") || res.Identity.StartsWith("//"))
                        {
                            rootName = parts[0]; // Simplified for now
                        }

                        if (!fileTreeRoots.ContainsKey(rootName))
                        {
                            fileTreeRoots[rootName] = new TreeNode { Name = rootName, FullPath = rootName, IsExpanded = true };
                        }
                        fileTreeRoots[rootName].AddPath(res.Identity, res, 1);
                    }
                }
            }
        }
    }

    bool IsTreeViewSupported(string resultType)
    {
        return resultType == "FILE" || resultType == "REGISTRY" || resultType == "PORT";
    }

    public void ParseOptsToResultTypes()
    {
        foundResultTypes.Clear();
        if (AttackSurfaceAnalyzerClient.DatabaseManager is null)
        {
            return;
        }        
        foreach (var resultType in Enum.GetValues(typeof(RESULT_TYPE)))
        {
            var found = AttackSurfaceAnalyzerClient.DatabaseManager.GetComparisonResultsCount(FirstRunId, SecondRunId, AnalysesHash, (int)resultType);
            if (found == 0)
            {
                found = AttackSurfaceAnalyzerClient.DatabaseManager.GetComparisonResultsCount(string.Empty, MonitorRunId, AnalysesHash, (int)resultType);
            }
            if (found > 0)
            {
                foundResultTypes.Add((RESULT_TYPE)resultType, found);
            }
        }
        if (foundResultTypes.Any())
        {
            _selectedResultType = foundResultTypes.First().Key.ToString();
        }
    }
}
